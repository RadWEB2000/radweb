{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "app/*":["./app/*"],
      "assets/*":["./src/assets/*"],
      "buttons/*":["./src/components/Utils/Buttons/*"],
      "c-person/*":["./src/components/Utils/Cards/PersonCard/*"],
      "c-blog/*":["./src/components/Utils/Cards/BlogCard/*"],
      "c-projects/*":["./src/components/Utils/Cards/ProjectCard/*"],
      "c-service/*":["./src/components/Utils/Cards/ServiceCard/*"],
      "cards/*":["./src/components/Utils/Cards/*"],
      "components/*":["./src/components/*"],
      "configs/*":["./src/configs/*"],
      "context/*":["./src/context/*"],
      "css/*":["./src/styles/*"],
      "data/*":["./src/data/*"],
      "footer/*":["./src/components/Layout/Footer/*"],
      "functions/*":["./src/lib/functions/*"],
      "hooks/*":["./src/lib/hooks/*"],
      "img/*":["./src/assets/images/*"],
      "l-footer/*":["./src/components/Layout/Footer/*"],
      "l-nav/*":["./src/components/Layout/Navigation/*"],
      "l-seo/*":["./src/components/Layout/Seo/*"],
      "layout/*":["./src/components/Layout/*"],
      "lib/*":["./src/lib/*"],
      "movies/*":["./src/assets/movies/*"],
      "public/*": ["./public/*"],
      "src/*":["./src/*"],
      "ts/*":["./src/types/*"],
      "utils/*":["./src/components/Utils/*"],
      "views/*":["./src/components/Views/*"],
      "v-home/*":["./src/components/Views/HomeView/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
