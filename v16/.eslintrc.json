{
	"extends": ["next/core-web-vitals", "next/typescript", "prettier"],
	"parserOptions": {
		"ecmaVersion": 2020,
		"sourceType": "module"
	},
	"env": {
		"browser": true,
		"es6": true,
		"node": true
	},
	"plugins": ["react", "tailwindcss"],
	"rules": {
		"indent": ["tab"],
		"@next/next/no-img-element": "off"
	}
}
