{
    "arrowParens": "always",
    "jsxSingleQuote": true,
    "bracketSameLine": false,
    "proseWrap": "always",
    "requirePragma": false,
    "semi": true,
    "singleAttributePerLine": true,
    "singleQuote": true,
    "bracketSpacing": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": true,
    "plugins": ["prettier-plugin-tailwindcss"]
}